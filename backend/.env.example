# ─── RBIS Environment Configuration ─────────────────────────────────────────
#
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES.
# DO NOT commit .env to git — it is already in .gitignore.
#
# Generate a strong SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Retail Behavior Intelligence System"
APP_VERSION="2.0.0"
# IMPORTANT: set to false in production
DEBUG=false
# IMPORTANT: replace with output of: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_ME_use_secrets.token_hex(32)"

# ── CORS — set to your actual frontend URL in production ──────────────────────
# Self-hosted (phone on same LAN): leave as-is — any origin on port 8000 is fine
# Cloudflare Pages deployment: '["https://your-project.pages.dev"]'
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (fine for single-site deployment)
DATABASE_URL="sqlite+aiosqlite:///./data/rbis.db"
# Production multi-site: use PostgreSQL
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/rbis"

# ── Redis (optional — set USE_REDIS=true if you have Redis) ──────────────────
REDIS_URL="redis://localhost:6379/0"
USE_REDIS=false

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND="local"
LOCAL_STORAGE_PATH="./data"
# S3 (leave blank if not using):
S3_BUCKET_NAME=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Video ─────────────────────────────────────────────────────────────────────
NUM_CAMERAS=5
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=25
PROCESSING_FPS=5
USE_GPU=false

# ── Suspicion Scoring ─────────────────────────────────────────────────────────
SCORE_PICK_ITEM=10
SCORE_HOLD_ITEM_PER_10S=5
SCORE_MULTI_ITEM=10
SCORE_AVOID_REGISTER=15
SCORE_MOVE_TO_EXIT=20
SCORE_RETURN_ITEM=-15
SCORE_COMPLETE_CHECKOUT=-50
SCORE_IDLE_PER_10S=-1
THRESHOLD_WATCH=31
THRESHOLD_HIGH=61

# ── Alerts ────────────────────────────────────────────────────────────────────
ALERT_CLIP_SECONDS_BEFORE=10
ALERT_CLIP_SECONDS_AFTER=10

# ── Notifications (leave blank to disable) ────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
SENDGRID_API_KEY=""
ALERT_EMAIL_FROM=""
ALERT_EMAIL_TO=""

# ── Report Generation ─────────────────────────────────────────────────────────
REPORT_GENERATION_HOUR=23
REPORT_GENERATION_MINUTE=55

# ── Security Limits ───────────────────────────────────────────────────────────
WS_MAX_CONNECTIONS=100
WS_MAX_MESSAGE_SIZE=65536
RATE_LIMIT_PER_MINUTE=300
